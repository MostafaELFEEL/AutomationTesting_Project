<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="System Tests">

    <listeners>
        <listener class-name="TestHelperPack.TestListener"/>
    </listeners>

    <test name="API Execution" preserve-order="true">
        <classes>
            <class name="TestScripts.APITests"/>
        </classes>
    </test>

    <test name="Account Dependent Execution" parallel="methods" thread-count="12">
        <classes>
            <class name="TestScripts.AccountDependentTests"/>
        </classes>
    </test>

    <test name="Account Independent Execution" parallel="methods" thread-count="12">
        <classes>
            <class name="TestScripts.AccountIndependentTests"/>
        </classes>
    </test>

</suite>